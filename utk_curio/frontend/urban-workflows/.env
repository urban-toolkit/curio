BACKEND_URL=http://localhost:5002
VITE_GOOGLE_OAUTH_CLIENT_ID=908773882824-tq29rfa0ipv8ksbuamipnnfuitg472ss.apps.googleusercontent.com
# When true, Curio binds dev servers to 0.0.0.0 (LAN-reachable) and the
# frontend resolves BACKEND_URL from window.location at runtime so anyone
# on the network can join via http://<host-LAN-IP>:8080.
# Leave false for solo local dev (loopback only).
ENABLE_COLLAB=true