{
  "$schema": "https://raw.githubusercontent.com/urban-toolkit/curio/main/docs/schemas/node-package.v3.json",
  "id": "ai.urbanlab.uhvi",
  "version": "1.0.0",
  "name": "Urban Heat Vulnerability Index",
  "publisher": "Urban Analytics Lab",
  "description": "Loads and aggregates Urban Heat Vulnerability Index (UHVI) raster data and reduces it to per-feature attributes.",
  "license": "MIT",
  "compatibility": {
    "curioRuntime": ">=0.5.0",
    "major": 1
  },
  "permissions": [
    "filesystem.read",
    "network.fetch"
  ],
  "dependencies": {
    "packages": {},
    "python": {
      "rasterio": "^1.3",
      "numpy": "^1.26",
      "geopandas": "^0.14"
    },
    "js": {}
  },
  "kinds": [
    {
      "id": "uhvi-load",
      "label": "UHVI Loader",
      "category": "data",
      "engine": "python",
      "description": "Load a UHVI raster from a path or URL into a Curio-compatible Raster dataset.",
      "icon": null,
      "editor": "code",
      "hasCode": true,
      "hasWidgets": true,
      "hasGrammar": false,
      "inputPorts": [],
      "outputPorts": [
        {
          "types": [
            "RASTER",
            "DATAFRAME"
          ],
          "cardinality": "[1,n]"
        }
      ],
      "source": "sources/uhvi-load.py",
      "lifecycle": "code"
    },
    {
      "id": "uhvi-zones",
      "label": "UHVI Zones",
      "category": "data",
      "engine": "python",
      "description": "Load a polygon GeoDataFrame (e.g., census tracts) to use as the zonal-aggregation footprint.",
      "icon": null,
      "editor": "code",
      "hasCode": true,
      "hasWidgets": true,
      "hasGrammar": false,
      "inputPorts": [],
      "outputPorts": [
        {
          "types": [
            "GEODATAFRAME"
          ],
          "cardinality": "1"
        }
      ],
      "source": "sources/uhvi-zones.py",
      "lifecycle": "code"
    },
    {
      "id": "uhvi-zonal",
      "label": "UHVI Zonal Stats",
      "category": "computation",
      "engine": "python",
      "description": "Compute zonal statistics of a UHVI raster over a polygon GeoDataFrame.",
      "icon": null,
      "editor": "code",
      "hasCode": true,
      "hasWidgets": true,
      "hasGrammar": false,
      "inputPorts": [
        {
          "types": [
            "RASTER",
            "GEODATAFRAME"
          ],
          "cardinality": "[1,2]"
        }
      ],
      "outputPorts": [
        {
          "types": [
            "GEODATAFRAME"
          ],
          "cardinality": "1"
        }
      ],
      "source": "sources/uhvi-zonal.py",
      "lifecycle": "code"
    }
  ],
  "createdAt": "2024-01-01T10:00:00Z"
}
