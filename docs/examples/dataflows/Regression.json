        "y": 150,
        "content": "{\n  \"map\": {\n    \"layerRefs\": [\n      {\n        \"dataRef\": \"table_osm_surface\"\n      },\n      {\n        \"dataRef\": \"table_osm_parks\"\n      },\n      {\n        \"dataRef\": \"table_osm_water\"\n      },\n      {\n        \"dataRef\": \"table_osm_roads\",\n        \"isPick\": true,\n        \"getFnv\": \"lanes_norm\",\n        \"getFnvType\": \"quantitative\",\n        \"defaultFnv\": 1\n      }\n    ]\n  }\n}",
