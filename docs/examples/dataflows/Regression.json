        "y": 400,
        "content": "{\n  \"compute\": [\n    {\n      \"dataRef\": \"table_osm_roads\",\n      \"attributes\": {\n        \"x\": \"lanes\"\n      },\n      \"outputColumnName\": \"lanes_norm\",\n      \"wglsFunction\": \"if (x <= 0.0) { return 1.0; } if (x > 8.0) { return 8.0; } return x;\"\n    }\n  ]\n}",
        "out": "DEFAULT",
        "in": "DEFAULT",
        "goal": "Normalise lane count via GPU — clamp to the 1–8 range.",
        "metadata": {
          "keywords": []
        }
      },
      {
