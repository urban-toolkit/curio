        "content": "{\n  \"data\": [\n    {\n      \"type\": \"osm\",\n      \"pbfFileUrl\": \"docs/examples/data/niteroi.osm.pbf\",\n      \"queryArea\": {\n        \"geocodeArea\": \"Rio de Janeiro\",\n        \"areas\": [\n          \"Niterói\"\n        ]\n      },\n      \"outputTableName\": \"table_osm\",\n      \"autoLoadLayers\": {\n        \"layers\": [\n          \"surface\",\n          \"parks\",\n          \"water\",\n          \"roads\"\n        ],\n        \"dropOsmTable\": true\n      }\n    },\n    {\n      \"type\": \"join\",\n      \"tableRootName\": \"table_osm_roads\",\n      \"tableJoinName\": \"table_osm_surface\",\n      \"near\": {\n        \"distance\": 50\n      },\n      \"groupBy\": [\n        {\n          \"column\": \"osm_id\",\n          \"aggregateFn\": \"count\"\n        }\n      ]\n    }\n  ]\n}",
        "out": "DEFAULT",
        "in": "DEFAULT",
        "goal": "Load Niteroi OSM road network (surface, parks, water, roads) from PBF and run a spatial join of roads against the surface layer.",
        "metadata": {
          "keywords": []
        }
